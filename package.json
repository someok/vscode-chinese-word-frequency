{
  "name": "vscode-chinese-word-frequency",
  "displayName": "Chinese Word Frequency",
  "description": "Analyze Chinese word frequency in the active editor and highlight selected terms.",
  "version": "1.0.0",
  "publisher": "someok",
  "license": "MIT",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "icon": "media/icon.png",
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/someok/vscode-chinese-word-frequency.git"
  },
  "homepage": "https://github.com/someok/vscode-chinese-word-frequency",
  "bugs": {
    "url": "https://github.com/someok/vscode-chinese-word-frequency/issues"
  },
  "contributes": {
    "commands": [
      { "command": "wordFrequency.analyzeActiveEditor", "title": "Analyze Active Editor", "category": "Word Frequency" },
      { "command": "wordFrequency.highlightTerm", "title": "Highlight Term", "category": "Word Frequency" }
    ],
    "views": {
      "explorer": [
        {
          "id": "wordFrequencyView",
          "name": "词频分析",
          "icon": "media/view-icon.svg",
          "contextualTitle": "词频分析"
        }
      ]
    },
    "menus": {
      "view/title": [
        { "command": "wordFrequency.analyzeActiveEditor", "when": "view == wordFrequencyView", "group": "navigation" }
      ]
    },
    "configuration": {
      "title": "Word Frequency",
      "properties": {
        "wordFrequency.ignoreTerms": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "scope": "resource",
          "markdownDescription": "Terms to ignore while counting. One item per line. User + Workspace + Workspace Folder values are merged and deduplicated."
        },
        "wordFrequency.maxResults": {
          "type": "number",
          "default": 300,
          "minimum": 10,
          "scope": "resource",
          "markdownDescription": "Maximum number of frequency rows displayed in the panel."
        }
      }
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit -p ./",
    "compile": "npm run check-types && node ./scripts/build.mjs",
    "compile:prod": "npm run check-types && node ./scripts/build.mjs --production",
    "watch": "node ./scripts/build.mjs --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "vscode:prepublish": "npm run compile:prod",
    "package": "npx @vscode/vsce package"
  },
  "dependencies": {
    "segmentit": "^2.0.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.13.0",
    "@types/node": "^22.10.1",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.11",
    "eslint": "^9.21.0",
    "typescript": "^5.8.2"
  }
}
